{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Welcome to MkDocs","text":"<p>For full documentation visit mkdocs.org.</p>"},{"location":"#commands","title":"Commands","text":"<ul> <li><code>mkdocs new [dir-name]</code> - Create a new project.</li> <li><code>mkdocs serve</code> - Start the live-reloading docs server.</li> <li><code>mkdocs build</code> - Build the documentation site.</li> <li><code>mkdocs -h</code> - Print help message and exit.</li> </ul>"},{"location":"#project-layout","title":"Project layout","text":"<pre><code>mkdocs.yml    # The configuration file.\ndocs/\n    index.md  # The documentation homepage.\n    ...       # Other markdown pages, images and other files.\n</code></pre>"},{"location":"MainPage/","title":"MainPage","text":"\u6b22\u8fce\u6765\u5230\u6211\u7684\u4e3b\u9875"},{"location":"reference/","title":"\u642d\u5efa\u672c\u7f51\u7ad9\u7684\u4e00\u4e9b\u53c2\u8003\u8d44\u6599","text":"<ol> <li> <p>\u4e86\u89e3GitHub Pages</p> </li> <li> <p>\u4f7f\u7528Mkdocs\u521d\u6b65\u642d\u5efa\u7f51\u7ad9</p> </li> <li> <p>\u4e00\u4e2a\u53ef\u4ee5\u53c2\u8003\u7684\u7f51\u7ad9\u914d\u7f6e</p> </li> <li> <p>\u5b98\u65b9\u914d\u7f6e\u6307\u5357</p> </li> <li> <p>\u53e6\u4e00\u4e2a\u53ef\u4ee5\u53c2\u8003\u7684\u642d\u5efa\u6307\u5bfc</p> </li> </ol>"},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/","title":"\u672c\u5468\u89c4\u5212","text":""},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_1","title":"\u672c\u5468\u8ba1\u5212\uff08\u4e0e\u65e5\u66f4\u65b0\uff09","text":"\u5e8f\u53f7 \u661f\u671f\u4e00 \u661f\u671f\u4e8c \u661f\u671f\u4e09 \u661f\u671f\u56db \u661f\u671f\u4e94 \u661f\u671f\u516d \u661f\u671f\u65e5 1 \u7ed8\u56fe\u5404\u90e8\u5206\u6574\u5408 \u5f62\u5f0f\u8bed\u8a00\u4e0e\u7f16\u8bd1 ICS-lab1 2 \u5f62\u5f0f\u8bed\u8a00\u4e0e\u7f16\u8bd1 \u8ba1\u7b97\u673a\u7cfb\u7edf\u5bfc\u8bba \u8ba1\u7b97\u6982\u8bba\u4f5c\u4e1a \u7535\u5b50\u6280\u672f\u57fa\u7840 \u4e60\u6982 3 \u4f53\u80b2 \u7ed8\u56fe\u7b2c\u4e09\u90e8\u5206 \u8ba1\u7b97\u6982\u8bba\u4f5c\u4e1a \u8ba1\u7b97\u673a\u7cfb\u7edf\u5bfc\u8bba ICS-lab1 4 \u6c47\u7f16\u8bed\u8a00 \u4e60\u6982\u3001\u7ed8\u56fe\u7b2c\u4e09\u90e8\u5206 \u5c0f\u7ec4\u7ec4\u4f1a\uff08\u672c\u5468\u65e0\uff09 \u6c47\u7f16\u8bed\u8a00 \u8bba\u6587\u590d\u73b0 5 \u8ba1\u7b97\u6982\u8bba \u7535\u5b50\u6280\u672f\u57fa\u7840 \u9605\u8bfb\u8bba\u6587 \u67e5\u770b\u81ea\u4fee\u7533\u8bf7 \u8bba\u6587\u590d\u73b0 \u7efc\u5de5\u7406\u8bba\u8bfe \u665a\u4e0a \u7ed8\u56fe\u7b2c\u56db\u90e8\u5206 \u9605\u8bfb\u8bba\u6587 ICS-lab0 <p>[!TIP]</p> <p>\u5468\u4e09\u665a\u4e0a\u7684\u8ba1\u7b97\u6982\u8bba\u4f5c\u4e1a\u90e8\u5206\u4e3b\u8981\u662f\u89c4\u5212\u597d\u4f5c\u4e1a\u8fdb\u5ea6\uff0c\u5e76\u5b8c\u6210\u4e00\u4e9b\u5f88\u7b80\u5355\u7684\u90e8\u5206</p>"},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_2","title":"\u8bfe\u8868","text":""},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_3","title":"\u5e38\u7528\u7f51\u7ad9","text":"<ul> <li> <p>\u9996\u9875 - \u601d\u6e90\u5b66\u58022.0</p> </li> <li> <p>AtomGit | GitCode - \u5168\u7403\u5f00\u53d1\u8005\u7684\u5f00\u6e90\u793e\u533a,\u5f00\u6e90\u4ee3\u7801\u6258\u7ba1\u5e73\u53f0</p> </li> </ul>"},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_4","title":"\u5f62\u5f0f\u8bed\u8a00\u4e0e\u7f16\u8bd1","text":"<p>[!TIP]</p> <p>x</p>"},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_5","title":"\u6c47\u7f16\u8bed\u8a00","text":"<p>[!TIP]</p> <p>x </p>"},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_6","title":"\u8ba1\u7b97\u6982\u8bba","text":"<ul> <li> \u9605\u8bfb\u8bfe\u4e0a\u4ecb\u7ecd\u7684\u4e24\u7bc7\u6587\u7ae0\uff0c\u5e76\u603b\u7ed3\u3002\u6587\u7ae0\u4e00;\u6587\u7ae0\u4e8c</li> <li> \u4e3a\u4ec0\u4e48\u8bf4\u8ba1\u7b97\u601d\u7ef4\u7684\u6838\u5fc3\u662f\u201c\u6784\u9020\u201d\uff0c\u800c\u6784\u9020\u7684\u4efb\u52a1\u662f\u62bd\u8c61\u4e0e\u81ea\u52a8\u5316\uff1f\u4f60\u53ef\u4ee5\u7528\u8eab\u8fb9\u7684\u4f8b\u5b50\u4e3e\u4f8b\u8bf4\u660e\u4ec0\u4e48\u662f\u8ba1\u7b97\u601d\u7ef4\u5417\uff1f</li> <li> \u5728gitcode\u5f00\u6e90\u4ee3\u7801\u5e73\u53f0\u6ce8\u518c\u4e00\u4e2a\u8d26\u53f7\uff0c\u5e76\u901a\u8fc7\u4ee3\u7801\u4ed3\u5e93\u7684fork\u548cPR\uff08Pull Request\uff09\uff0c\u5b9e\u73b0\u4ee3\u7801\u7684\u63d0\u4ea4\u3002   \u4ee3\u7801\u4ed3\u5e93\u94fe\u63a5</li> </ul> <p>[!TIP] \u6240\u6709\u7684\u7406\u8bba\u4f5c\u4e1a\u4ea4\u601d\u6e90\u5b66\u5802\uff0c\u7a0b\u5e8f\u4f5c\u4e1a\u4ea4<code>gitcode</code></p>"},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_7","title":"\u8ba1\u7b97\u673a\u7cfb\u7edf\u5bfc\u8bba","text":"<ul> <li> \u5b8c\u6210<code>lab0</code>\uff0c\u5373\u5b8c\u6210\u5b9e\u9a8c\u73af\u5883\u7684\u914d\u7f6e</li> <li> <code>datalab</code>\u5728\u5468\u56db\u5f00\u59cb\uff0c\u8981\u8ddf\u4e0a\u8282\u594f</li> <li> \u627e\u5230\u82f1\u6587\u539f\u7248\u6559\u6750</li> <li> \u4ed4\u7ec6\u6d4f\u89c8\u8bfe\u7a0b\u4e3b\u9875\uff0c\u4ee5\u4fbf\u4ee5\u540e\u80fd\u65b9\u4fbf\u4f7f\u7528</li> </ul> <p>[!TIP]</p> <p>\u4e25\u9632\u4f5c\u5f0a\uff01\uff01</p>"},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_8","title":"\u7535\u5b50\u6280\u672f\u57fa\u7840","text":"<p>[!TIP]</p> <p>X</p>"},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_9","title":"\u6e38\u620f\u8bbe\u8ba1","text":"<ul> <li> \u628a\u4e0a\u8bfe\u65f6\u95f4\u6807\u8bb0\u597d\uff0c\u4e86\u89e3\u8bfe\u7a0b\u8fdb\u5ea6</li> </ul> <p>[!TIP]</p> <p>\u8bfe\u7a0b\u5b89\u6392\u94fe\u63a5</p>"},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_10","title":"\u79d1\u7814\u4efb\u52a1","text":"<ul> <li> <p> \u7ee7\u7eed\u7ed8\u56fe</p> </li> <li> <p> \u8bfb\u7b2c\u4e00\u7bc7\u8bba\u6587\u5e76\u590d\u73b0</p> </li> <li> <p> \u4e0a\u4ea4\u8fd9\u5468\u7684\u79d1\u7814\u4efb\u52a1</p> </li> </ul>"},{"location":"%E5%BE%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/#_11","title":"\u5176\u4ed6\u6742\u9879","text":"<ul> <li> <p> \u6210\u529f\u90e8\u7f72\u4e00\u6b21<code>GitHub</code>\u4e0a\u7684\u9879\u76ee\uff0c\u5199\u4e00\u7bc7\u7ecf\u9a8c\u8d34</p> </li> <li> <p> \u5199\u4e00\u4e2a\u6252\u53d6\u8bba\u6587\u7684\u811a\u672c\uff0c\u5e76\u8bbe\u8ba1\u597d\u6570\u636e\u5e93\uff0c\u53ef\u4ee5\u8bd5\u8bd5\u524d\u9762\u5bd2\u5047\u4f5c\u4e1a\u4e2d\u5b66\u5230\u7684</p> </li> <li> <p> \u6574\u5408\u4ee5\u4e0b\u4e0a\u5b66\u671f\u7684\u5fb7\u80b2\u8d44\u6599\uff0c\u770b\u770b\u8fd8\u6709\u54ea\u4e9b\u7f3a\u5c11\u7684</p> </li> <li> <p> \u770b\u770b\u6700\u8fd1\u5f97\u5230\u7684\u51e0\u4e2a\u6bd4\u8d5b\u6216\u8005\u9879\u76ee\u4fe1\u606f\uff0c\u770b\u770b\u6709\u6ca1\u6709\u5408\u9002\u7684</p> </li> <li> <p> \u7814\u7a76\u4ee5\u4e0b<code>obsidian</code>\u8be5\u600e\u4e48\u7528</p> </li> </ul>"}]}